<Controls:MetroWindow
    x:Class="Orbit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:converters="clr-namespace:Orbit.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dragablz="clr-namespace:Dragablz;assembly=Dragablz"
    xmlns:dockablz="clr-namespace:Dragablz.Dockablz;assembly=Dragablz"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Orbit"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:Orbit.Models"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:viewmodels="clr-namespace:Orbit.ViewModels"
    xmlns:views="clr-namespace:Orbit.Views"
    Title="Orbit"
    Width="1400"
    Height="1000"
    d:DataContext="{d:DesignInstance viewmodels:MainWindowViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="1000"
    d:DesignWidth="1400"
    Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
    PreviewKeyUp="MainWindow_PreviewKeyUp"
    PreviewMouseUp="MainWindow_PreviewMouseUp"
    ShowIconOnTitleBar="False"
    ShowTitleBar="True"
    SizeChanged="MetroWindow_SizeChanged"
    TitleBarHeight="35"
    TitleCharacterCasing="Normal"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Controls:MetroWindow.TaskbarItemInfo>
        <shell:TaskbarItemInfo x:Name="TaskbarInfo" Description="Orbit">
            <shell:TaskbarItemInfo.ThumbnailClipMargin>
                <Thickness>0</Thickness>
            </shell:TaskbarItemInfo.ThumbnailClipMargin>
        </shell:TaskbarItemInfo>
    </Controls:MetroWindow.TaskbarItemInfo>

    <Controls:MetroWindow.TitleTemplate>
        <DataTemplate>
            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                <Border
                    Width="32"
                    Height="32"
                    Margin="0,0,10,0"
                    Background="Transparent"
                    CornerRadius="16">
                    <Viewbox Margin="5">
                        <Image
                            Width="16"
                            Height="16"
                            Source="{DynamicResource Orbit.IconImage}"
                            Stretch="Uniform" />
                    </Viewbox>
                </Border>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Orbit.Brushes.Text.OnHeader}"
                    Text="{Binding}" />
            </StackPanel>
        </DataTemplate>
    </Controls:MetroWindow.TitleTemplate>

    <d:Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  MahApps Dark Theme for Designer  -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Blue.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </d:Window.Resources>

    <Window.Resources>
        <!--  Converters  -->
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:SessionStateToColorConverter x:Key="SessionStateToColorConverter" />
        <converters:InjectionStateToColorConverter x:Key="InjectionStateToColorConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ConsoleLogLevelToBrushConverter x:Key="ConsoleLogLevelToBrushConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:IsOfTypeConverter x:Key="IsOfTypeConverter" />
        <converters:EqualityToVisibilityConverter x:Key="EqualityToVisibilityConverter" />
        <converters:SubtractConverter x:Key="SubtractConverter" />
        <converters:RatioToSizeConverter x:Key="RatioToSizeConverter" />
        <converters:DockZoneHighlightConverter x:Key="DockZoneHighlightConverter" />
        <Style x:Key="Orbit.FloatingMenuToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent3}" />
            <Setter Property="Tag" Value="1.5" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0" Color="{DynamicResource MahApps.Colors.Accent}" />
                        <GradientStop Offset="1" Color="{DynamicResource MahApps.Colors.Accent2}" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>

                            <Ellipse
                                x:Name="Glow"
                                Margin="-6"
                                Fill="{DynamicResource MahApps.Brushes.Accent}"
                                Opacity="0">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="12" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <Ellipse
                                x:Name="BaseCircle"
                                Fill="{TemplateBinding Background}"
                                Stroke="{TemplateBinding BorderBrush}"
                                StrokeThickness="{TemplateBinding Tag}" />
                            <Ellipse
                                x:Name="HoverRing"
                                Margin="-1"
                                Opacity="0.14"
                                Stroke="{DynamicResource MahApps.Brushes.AccentForeground}"
                                StrokeThickness="1.4" />

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />

                            <Polygon
                                x:Name="IndicatorLeft"
                                Fill="{DynamicResource MahApps.Brushes.Accent}"
                                Opacity="0.9"
                                Points="0,12 0,0 12,0"
                                Visibility="Collapsed">
                                <Polygon.RenderTransform>
                                    <TranslateTransform X="6" Y="18" />
                                </Polygon.RenderTransform>
                            </Polygon>
                            <Polygon
                                x:Name="IndicatorRight"
                                Fill="{DynamicResource MahApps.Brushes.Accent}"
                                Opacity="0.9"
                                Points="0,0 12,0 12,12"
                                Visibility="Collapsed">
                                <Polygon.RenderTransform>
                                    <TranslateTransform X="30" Y="18" />
                                </Polygon.RenderTransform>
                            </Polygon>
                            <Polygon
                                x:Name="IndicatorUp"
                                Fill="{DynamicResource MahApps.Brushes.Accent}"
                                Opacity="0.9"
                                Points="0,0 12,0 0,12"
                                Visibility="Collapsed">
                                <Polygon.RenderTransform>
                                    <TranslateTransform X="18" Y="6" />
                                </Polygon.RenderTransform>
                            </Polygon>
                            <Polygon
                                x:Name="IndicatorDown"
                                Fill="{DynamicResource MahApps.Brushes.Accent}"
                                Opacity="0.9"
                                Points="12,0 12,12 0,12"
                                Visibility="Collapsed">
                                <Polygon.RenderTransform>
                                    <TranslateTransform X="18" Y="30" />
                                </Polygon.RenderTransform>
                            </Polygon>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverRing" Property="Opacity" Value="0.34" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                FillBehavior="HoldEnd"
                                                Storyboard.TargetName="ScaleTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1.06"
                                                Duration="0:0:0.12" />
                                            <DoubleAnimation
                                                FillBehavior="HoldEnd"
                                                Storyboard.TargetName="ScaleTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1.06"
                                                Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ScaleTransform"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1"
                                                Duration="0:0:0.14" />
                                            <DoubleAnimation
                                                Storyboard.TargetName="ScaleTransform"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1"
                                                Duration="0:0:0.14" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                <Setter TargetName="Glow" Property="Opacity" Value="0.6" />
                                <Setter TargetName="HoverRing" Property="Opacity" Value="0.6" />
                                <Setter TargetName="BaseCircle" Property="StrokeThickness" Value="2" />
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BaseCircle" Property="Opacity" Value="0.4" />
                                <Setter TargetName="HoverRing" Property="Opacity" Value="0" />
                            </Trigger>

                            <DataTrigger Binding="{Binding FloatingMenuActiveSide}" Value="{x:Static models:FloatingMenuDirection.Left}">
                                <Setter TargetName="IndicatorLeft" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FloatingMenuActiveSide}" Value="{x:Static models:FloatingMenuDirection.Right}">
                                <Setter TargetName="IndicatorRight" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FloatingMenuActiveSide}" Value="{x:Static models:FloatingMenuDirection.Up}">
                                <Setter TargetName="IndicatorUp" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FloatingMenuActiveSide}" Value="{x:Static models:FloatingMenuDirection.Down}">
                                <Setter TargetName="IndicatorDown" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid MouseUp="RootGrid_MouseUp">
        <!--  Main Content Area  -->
        <DockPanel>

            <!--  Main shell layout enables side-by-side snapping outside Orbit View  -->
            <dockablz:Layout Partition="OrbitMainShell">
                <dockablz:Layout.BranchTemplate>
                    <DataTemplate>
                        <dragablz:TabablzControl
                            Padding="5"
                            ContentTemplateSelector="{StaticResource TabContentTemplateSelector}"
                            Loaded="MainShellBranchTabControl_Loaded"
                            SelectionChanged="MainShellTabControl_SelectionChanged"
                            Style="{StaticResource Orbit.TabablzControlStyle}"
                            ShowDefaultCloseButton="True">
                            <dragablz:TabablzControl.InterTabController>
                                <dragablz:InterTabController
                                    InterTabClient="{Binding DataContext.InterTabClient, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Partition="OrbitMainShell" />
                            </dragablz:TabablzControl.InterTabController>
                        </dragablz:TabablzControl>
                    </DataTemplate>
                </dockablz:Layout.BranchTemplate>

                <!--  TabablzControl bound to Sessions and InterTabClient  -->
                <dragablz:TabablzControl
                    x:Name="SessionTabControl"
                    Padding="5"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                    SelectionChanged="MainShellTabControl_SelectionChanged"
                    ShowDefaultCloseButton="True"
                    Style="{StaticResource Orbit.TabablzControlStyle}"
                    ContentTemplateSelector="{StaticResource TabContentTemplateSelector}">

                <!--  InterTabController with binding to InterTabClient  -->
                    <dragablz:TabablzControl.InterTabController>
                        <dragablz:InterTabController InterTabClient="{Binding InterTabClient}" Partition="OrbitMainShell" />
                    </dragablz:TabablzControl.InterTabController>
                </dragablz:TabablzControl>
            </dockablz:Layout>

        </DockPanel>

        <!--  Empty State Background - Branded Orbit Logo (Overlay)  -->
        <Grid
            Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
            IsHitTestVisible="False">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Tabs.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Viewbox
                Width="460"
                Height="460"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Grid Width="512">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="512" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.Resources>
                        <SolidColorBrush
                            x:Key="OrbitHome.IconBrush"
                            Opacity="0.85"
                            Color="{DynamicResource MahApps.Colors.Accent}" />
                        <SolidColorBrush
                            x:Key="OrbitHome.RingBrush"
                            Opacity="0.55"
                            Color="{DynamicResource MahApps.Colors.Accent2}" />
                        <SolidColorBrush
                            x:Key="OrbitHome.TextBrush"
                            Opacity="0.72"
                            Color="{DynamicResource MahApps.Colors.Accent}" />
                    </Grid.Resources>

                    <!--  Orbit Icon with theme-aware coloring using Canvas  -->
                    <Canvas
                        Grid.Row="0"
                        Width="512"
                        Height="512"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <Canvas.Effect>
                            <DropShadowEffect
                                BlurRadius="26"
                                Direction="315"
                                Opacity="0.28"
                                ShadowDepth="6"
                                Color="{DynamicResource MahApps.Colors.Accent}" />
                        </Canvas.Effect>

                        <!--  Main icon geometry using shared resource  -->
                        <Path Data="{StaticResource Orbit.IconGeometry}" Fill="{StaticResource OrbitHome.IconBrush}" />

                    </Canvas>

                    <!--  "Orbit" Text Below Icon  -->
                    <TextBlock
                        Grid.Row="1"
                        Margin="0,36,0,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        FontFamily="Segoe UI"
                        FontSize="72"
                        FontWeight="Black"
                        Foreground="{StaticResource OrbitHome.TextBrush}"
                        Text="Orbit"
                        TextOptions.TextFormattingMode="Ideal"
                        TextOptions.TextRenderingMode="Auto">
                        <TextBlock.Effect>
                            <DropShadowEffect
                                BlurRadius="14"
                                Direction="315"
                                Opacity="0.3"
                                ShadowDepth="4"
                                Color="{DynamicResource MahApps.Colors.Accent}" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Grid>
            </Viewbox>
        </Grid>

        <!--  Snap Zone Visual Indicators  -->
        <Grid
            x:Name="SnapZoneOverlay"
            Margin="8"
            IsHitTestVisible="False"
            Visibility="{Binding IsFloatingMenuDockOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.Resources>
                <Style x:Key="SnapIndicatorStyle" TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource MahApps.Brushes.Accent}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="CornerRadius" Value="24" />
                    <Setter Property="SnapsToDevicePixels" Value="True" />
                    <Setter Property="Opacity">
                        <Setter.Value>
                            <Binding Path="FloatingMenuDockZoneOpacity" />
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>

            <!--  Left Edge Indicator  -->
            <Border
                Width="{Binding FloatingMenuDockEdgeThreshold}"
                Margin="0,12,0,12"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Height>
                    <MultiBinding Converter="{StaticResource RatioToSizeConverter}">
                        <Binding ElementName="SnapZoneOverlay" Path="ActualHeight" />
                        <Binding Path="FloatingMenuDockEdgeCoverage" />
                    </MultiBinding>
                </Border.Height>
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.Left}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <!--  Right Edge Indicator  -->
            <Border
                Width="{Binding FloatingMenuDockEdgeThreshold}"
                Margin="0,12,0,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Height>
                    <MultiBinding Converter="{StaticResource RatioToSizeConverter}">
                        <Binding ElementName="SnapZoneOverlay" Path="ActualHeight" />
                        <Binding Path="FloatingMenuDockEdgeCoverage" />
                    </MultiBinding>
                </Border.Height>
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.Right}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <!--  Top Edge Indicator  -->
            <Border
                Height="{Binding FloatingMenuDockEdgeThreshold}"
                Margin="12,0,12,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource RatioToSizeConverter}">
                        <Binding ElementName="SnapZoneOverlay" Path="ActualWidth" />
                        <Binding Path="FloatingMenuDockEdgeCoverage" />
                    </MultiBinding>
                </Border.Width>
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.Top}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <!--  Bottom Edge Indicator  -->
            <Border
                Height="{Binding FloatingMenuDockEdgeThreshold}"
                Margin="12,0,12,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Width>
                    <MultiBinding Converter="{StaticResource RatioToSizeConverter}">
                        <Binding ElementName="SnapZoneOverlay" Path="ActualWidth" />
                        <Binding Path="FloatingMenuDockEdgeCoverage" />
                    </MultiBinding>
                </Border.Width>
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.Bottom}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <!--  Corner Indicators  -->
            <Border
                Width="{Binding FloatingMenuDockCornerThreshold}"
                Height="{Binding FloatingMenuDockCornerHeight}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                CornerRadius="{Binding FloatingMenuDockCornerRadius}"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.TopLeft}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <Border
                Width="{Binding FloatingMenuDockCornerThreshold}"
                Height="{Binding FloatingMenuDockCornerHeight}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                CornerRadius="{Binding FloatingMenuDockCornerRadius}"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.TopRight}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <Border
                Width="{Binding FloatingMenuDockCornerThreshold}"
                Height="{Binding FloatingMenuDockCornerHeight}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                CornerRadius="{Binding FloatingMenuDockCornerRadius}"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.BottomLeft}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>

            <Border
                Width="{Binding FloatingMenuDockCornerThreshold}"
                Height="{Binding FloatingMenuDockCornerHeight}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                CornerRadius="{Binding FloatingMenuDockCornerRadius}"
                Style="{StaticResource SnapIndicatorStyle}">
                <Border.Visibility>
                    <MultiBinding Converter="{StaticResource DockZoneHighlightConverter}">
                        <Binding Path="FloatingMenuDockCandidate" />
                        <Binding Source="{x:Static models:FloatingMenuDockRegion.BottomRight}" />
                        <Binding Path="ShowAllSnapZonesOnClip" />
                        <Binding Path="IsFloatingMenuClipping" />
                        <Binding Path="ShowAllSnapZonesOnDrag" />
                        <Binding Path="IsFloatingMenuDragging" />
                    </MultiBinding>
                </Border.Visibility>
            </Border>
        </Grid>

        <Grid
            x:Name="FloatingMenuOverlayAnchor"
            Margin="5"
            Background="Transparent"
            IsHitTestVisible="False" />

        <!--  Floating Orbit Menu (Popup to stay above embedded RS window)  -->
        <Popup
            x:Name="FloatingMenuHandlePopup"
            Width="Auto"
            Height="Auto"
            AllowsTransparency="True"
            Focusable="False"
            HorizontalOffset="{Binding FloatingMenuLeft}"
            IsOpen="{Binding IsFloatingMenuVisible, Mode=OneWay}"
            Placement="RelativePoint"
            PlacementTarget="{Binding ElementName=FloatingMenuOverlayAnchor}"
            StaysOpen="True"
            VerticalOffset="{Binding FloatingMenuTop}">
            <Grid>
                <Border
                    x:Name="FloatingMenuHandle"
                    Padding="6"
                    BorderBrush="{DynamicResource MahApps.Brushes.Accent3}"
                    BorderThickness="1.5"
                    CornerRadius="29"
                    MouseMove="FloatingMenu_MouseMove"
                    Opacity="{Binding FloatingMenuOpacity}"
                    PreviewMouseLeftButtonDown="FloatingMenuHandle_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="FloatingMenuHandle_PreviewMouseLeftButtonUp"
                    PreviewMouseMove="FloatingMenuHandle_PreviewMouseMove">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect" Value="{x:Null}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFloatingMenuWelcomeVisible, Mode=OneWay}" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect
                                                BlurRadius="20"
                                                Color="{DynamicResource MahApps.Colors.Accent}"
                                                Direction="0"
                                                Opacity="0.65"
                                                ShadowDepth="0" />
                                        </Setter.Value>
                                    </Setter>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="FloatingMenuHighlightPulse">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                    From="1"
                                                    To="1.08"
                                                    Duration="0:0:0.8" />
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                    From="1"
                                                    To="1.08"
                                                    Duration="0:0:0.8" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="FloatingMenuHighlightPulse" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.Background>
                        <LinearGradientBrush Opacity="0.94" StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="{DynamicResource MahApps.Colors.Accent}" />
                            <GradientStop Offset="1" Color="{DynamicResource MahApps.Colors.Accent2}" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <ToggleButton
                            x:Name="FloatingMenuToggleButton"
                            IsChecked="{Binding IsFloatingMenuExpanded, Mode=TwoWay}"
                            Style="{StaticResource Orbit.FloatingMenuToggleStyle}"
                            ToolTip="Orbit Controls">
                            <iconPacks:PackIconGameIcons
                                Width="32"
                                Height="32"
                                Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                Kind="Orbital" />
                            <ToggleButton.ContextMenu>
                                <ContextMenu>
                                    <MenuItem
                                        Header="Auto direction"
                                        IsCheckable="True"
                                        IsChecked="{Binding FloatingMenuAutoDirection, Mode=TwoWay}" />
                                    <Separator />
                                    <MenuItem
                                        Click="FloatingMenuSetSide_Click"
                                        Header="Left"
                                        Tag="Left" />
                                    <MenuItem
                                        Click="FloatingMenuSetSide_Click"
                                        Header="Right"
                                        Tag="Right" />
                                    <MenuItem
                                        Click="FloatingMenuSetSide_Click"
                                        Header="Up"
                                        Tag="Up" />
                                    <MenuItem
                                        Click="FloatingMenuSetSide_Click"
                                        Header="Down"
                                        Tag="Down" />
                                </ContextMenu>
                            </ToggleButton.ContextMenu>
                        </ToggleButton>
                    </Grid>
                </Border>

                <Popup
                    x:Name="FloatingMenuPopup"
                    AllowsTransparency="True"
                    HorizontalOffset="{Binding FloatingMenuPopupHorizontalOffset}"
                    IsOpen="{Binding IsFloatingMenuExpanded, Mode=TwoWay}"
                    Placement="{Binding FloatingMenuPopupPlacement}"
                    PlacementTarget="{Binding ElementName=FloatingMenuToggleButton}"
                    PopupAnimation="Fade"
                    StaysOpen="False"
                    VerticalOffset="{Binding FloatingMenuPopupVerticalOffset}">
                    <Border
                        x:Name="FloatingMenuPopupContent"
                        Padding="12"
                        Background="Transparent"
                        BorderBrush="{DynamicResource MahApps.Brushes.Accent2}"
                        BorderThickness="1.5"
                        CornerRadius="18"
                        MouseMove="FloatingMenu_MouseMove"
                        Opacity="1">
                        <Grid>
                            <Border
                                Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                CornerRadius="18"
                                Opacity="{Binding FloatingMenuBackgroundOpacity}">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="8"
                                        Direction="90"
                                        Opacity="0.15"
                                        ShadowDepth="1"
                                        Color="{DynamicResource MahApps.Colors.ThemeForeground}" />
                                </Border.Effect>
                            </Border>
                            <StackPanel Margin="10">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Orientation" Value="Vertical" />
                                        <Setter Property="FlowDirection" Value="LeftToRight" />
                                        <Setter Property="LayoutTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Left}">
                                                <Setter Property="Orientation" Value="Horizontal" />
                                                <Setter Property="FlowDirection" Value="RightToLeft" />
                                                <Setter Property="LayoutTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Right}">
                                                <Setter Property="Orientation" Value="Horizontal" />
                                                <Setter Property="FlowDirection" Value="LeftToRight" />
                                                <Setter Property="LayoutTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Up}">
                                                <Setter Property="Orientation" Value="Vertical" />
                                                <Setter Property="FlowDirection" Value="LeftToRight" />
                                                <Setter Property="LayoutTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="-1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <StackPanel.Resources>
                                    <Style
                                        x:Key="FloatingMenuButtonStyle"
                                        BasedOn="{StaticResource MahApps.Styles.Button.Circle}"
                                        TargetType="Button">
                                        <Setter Property="Width" Value="50" />
                                        <Setter Property="Height" Value="50" />
                                        <Setter Property="Margin" Value="5" />
                                        <Setter Property="LayoutTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1" ScaleY="1" />
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Up}">
                                                <Setter Property="LayoutTransform">
                                                    <Setter.Value>
                                                        <ScaleTransform ScaleX="1" ScaleY="-1" />
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Resources>

                                <Button
                                    Command="{Binding AddSessionCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Add Session"
                                    Visibility="{Binding ShowMenuAddSession, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="Plus" />
                                </Button>
                                <Button
                                    Command="{Binding InjectCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Inject Session"
                                    Visibility="{Binding ShowInjectMenuButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="Needle" />
                                </Button>
                                <Button
                                    Command="{Binding ShowSessionsCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Manage Sessions"
                                    Visibility="{Binding ShowMenuSessions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="ViewList" />
                                </Button>
                                <Button
                                    Command="{Binding OpenSessionGalleryCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Session Gallery"
                                    Visibility="{Binding ShowMenuSessionGallery, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="ViewModule" />
                                </Button>
                                <Button
                                    Command="{Binding OpenOrbitViewCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Orbit View"
                                    Visibility="{Binding ShowMenuOrbitView, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="ViewGrid" />
                                </Button>
                                <Button
                                    Command="{Binding OpenAccountManagerCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Account Manager"
                                    Visibility="{Binding ShowMenuAccountManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="AccountMultiple" />
                                </Button>
                                <Button
                                    Click="ScriptControlButton_Click"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Script Controls"
                                    Visibility="{Binding ShowMenuScriptControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="FileCodeOutline" />
                                </Button>
                                <Button
                                    Command="{Binding OpenThemeManagerCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Theme Manager"
                                    Visibility="{Binding ShowMenuThemeManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="Palette" />
                                </Button>
                                <Button
                                    Command="{Binding ToggleConsoleCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Toggle Console"
                                    Visibility="{Binding ShowMenuConsole, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="Console" />
                                </Button>
                                <Button
                                    Command="{Binding OpenMcpControlCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="MCP Control"
                                    Visibility="{Binding ShowMenuMcpControl, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="LanConnect" />
                                </Button>
                                <Button
                                    Command="{Binding OpenGuideCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="Guide"
                                    Visibility="{Binding ShowMenuGuide, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="BookOpenPageVariant" />
                                </Button>
                                <Grid Visibility="{Binding ShowMenuSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button
                                        Command="{Binding OpenSettingsCommand}"
                                        Style="{StaticResource FloatingMenuButtonStyle}"
                                        ToolTip="Settings">
                                        <iconPacks:PackIconMaterial Kind="Cog" />
                                    </Button>
                                    <TextBlock
                                        Margin="-3,-4,0,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        FontSize="20"
                                        FontWeight="Black"
                                        Foreground="{DynamicResource Orbit.UpdateBadgeBrush}"
                                        IsHitTestVisible="False"
                                        Text="!"
                                        Visibility="{Binding HasUpdateNotification, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1" />
                                        </TextBlock.RenderTransform>
                                        <TextBlock.Triggers>
                                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="Opacity"
                                                            From="1"
                                                            To="0.65"
                                                            Duration="0:0:0.8" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                            From="1"
                                                            To="1.06"
                                                            Duration="0:0:0.8" />
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                            From="1"
                                                            To="1.06"
                                                            Duration="0:0:0.8" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </TextBlock.Triggers>
                                        <TextBlock.Effect>
                                            <DropShadowEffect
                                                BlurRadius="10"
                                                Opacity="0.6"
                                                ShadowDepth="0"
                                                Color="{DynamicResource MahApps.Colors.Gray1}" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Grid>
                                <Button
                                    Command="{Binding OpenFsmNodeEditorCommand}"
                                    Style="{StaticResource FloatingMenuButtonStyle}"
                                    ToolTip="FSM Node Editor"
                                    Visibility="{Binding ShowMenuFsmNodeEditor, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <iconPacks:PackIconMaterial Kind="GraphOutline" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Popup>
                <Popup
                    x:Name="FloatingMenuWelcomePopup"
                    AllowsTransparency="True"
                    IsOpen="{Binding IsFloatingMenuWelcomeVisible, Mode=OneWay}"
                    PlacementTarget="{Binding ElementName=FloatingMenuHandle}"
                    PopupAnimation="Fade"
                    StaysOpen="False">
                    <Popup.Style>
                        <Style TargetType="Popup">
                            <Setter Property="Placement" Value="Top" />
                            <Setter Property="HorizontalOffset" Value="0" />
                            <Setter Property="VerticalOffset" Value="-24" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Down}">
                                    <Setter Property="Placement" Value="Bottom" />
                                    <Setter Property="VerticalOffset" Value="24" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Left}">
                                    <Setter Property="Placement" Value="Left" />
                                    <Setter Property="HorizontalOffset" Value="-24" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding FloatingMenuExpansionDirection}" Value="{x:Static models:FloatingMenuDirection.Right}">
                                    <Setter Property="Placement" Value="Right" />
                                    <Setter Property="HorizontalOffset" Value="24" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Popup.Style>
                    <Border
                        Background="{DynamicResource MahApps.Brushes.Accent}"
                        CornerRadius="18"
                        Padding="12"
                        Opacity="0.95">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="16"
                                Color="{DynamicResource MahApps.Colors.Accent}"
                                Direction="270"
                                Opacity="0.4"
                                ShadowDepth="4" />
                        </Border.Effect>
                        <Button
                            Command="{Binding FloatingMenuWelcomeCommand}"
                            Background="Transparent"
                            BorderBrush="{x:Null}"
                            Cursor="Hand"
                            FocusVisualStyle="{x:Null}"
                            Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                            Padding="0">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial
                                    Width="20"
                                    Height="20"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource MahApps.Brushes.AccentForeground}"
                                    Kind="HandPointingRight" />
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Text="Welcome!" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.85"
                                        Text="Click to open the Orbit menu" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </Border>
                </Popup>
            </Grid>
        </Popup>
    </Grid>
</Controls:MetroWindow>
