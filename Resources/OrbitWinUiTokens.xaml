<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- WinUI-style semantic tokens used by new surfaces while MahApps is still present. -->
    <Color x:Key="Orbit.Colors.CanvasBackground">#FF0B1020</Color>
    <Color x:Key="Orbit.Colors.CanvasNebulaA">#FF16213A</Color>
    <Color x:Key="Orbit.Colors.CanvasNebulaB">#FF0D1429</Color>
    <Color x:Key="Orbit.Colors.CardBackground">#CC1B2338</Color>
    <Color x:Key="Orbit.Colors.CardBorder">#66435A82</Color>
    <Color x:Key="Orbit.Colors.Accent">#FF61B0FF</Color>
    <Color x:Key="Orbit.Colors.AccentStrong">#FF9AD0FF</Color>
    <Color x:Key="Orbit.Colors.TextPrimary">#FFF3F7FF</Color>
    <Color x:Key="Orbit.Colors.TextSecondary">#BFD5E3FF</Color>
    <Color x:Key="Orbit.Colors.TextMuted">#809BB5D7</Color>
    <Color x:Key="Orbit.Colors.OrbitLine">#5E8DC4FF</Color>

    <SolidColorBrush x:Key="Orbit.Brushes.Canvas.Background" Color="{StaticResource Orbit.Colors.CanvasBackground}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Canvas.NebulaA" Color="{StaticResource Orbit.Colors.CanvasNebulaA}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Canvas.NebulaB" Color="{StaticResource Orbit.Colors.CanvasNebulaB}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Card.Background" Color="{StaticResource Orbit.Colors.CardBackground}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Card.Border" Color="{StaticResource Orbit.Colors.CardBorder}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Accent.Primary" Color="{StaticResource Orbit.Colors.Accent}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Accent.Strong" Color="{StaticResource Orbit.Colors.AccentStrong}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Text.Primary" Color="{StaticResource Orbit.Colors.TextPrimary}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Text.Secondary" Color="{StaticResource Orbit.Colors.TextSecondary}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Text.Tertiary" Color="{StaticResource Orbit.Colors.TextMuted}" />
    <SolidColorBrush x:Key="Orbit.Brushes.Orbit.Line" Color="{StaticResource Orbit.Colors.OrbitLine}" />
</ResourceDictionary>
