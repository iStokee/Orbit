<Application
    x:Class="Orbit.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:dragablz="clr-namespace:Dragablz;assembly=Dragablz"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:local="clr-namespace:Orbit"
    ShutdownMode="OnLastWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  MahApps.Metro v2 - Combined theme file (replaces separate base + accent)  -->
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Cyan.xaml" />

                <!--  Dragablz MahApps theme  -->
                <ResourceDictionary Source="pack://application:,,,/Dragablz;component/Themes/mahapps.xaml" />

                <!--  Orbit Session Templates - Unified across Main and Orbit View  -->
                <ResourceDictionary Source="Resources/SessionTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Dragablz MahApps theme compatibility keys expected by Dragablz/Themes/MahApps.xaml -->
            <SolidColorBrush x:Key="BlackBrush" Color="{DynamicResource MahApps.Colors.ThemeForeground}" />
            <SolidColorBrush x:Key="BlackColorBrush" Color="{DynamicResource MahApps.Colors.ThemeForeground}" />
            <SolidColorBrush x:Key="WhiteBrush" Color="{DynamicResource MahApps.Colors.IdealForeground}" />
            <SolidColorBrush x:Key="WhiteColorBrush" Color="{DynamicResource MahApps.Colors.IdealForeground}" />
            <SolidColorBrush x:Key="TransparentWhiteBrush" Color="#00FFFFFF" />
            <SolidColorBrush x:Key="SemiTransparentWhiteBrush" Color="#55FFFFFF" />
            <SolidColorBrush x:Key="HighlightBrush" Color="{DynamicResource MahApps.Colors.Highlight}" />
            <SolidColorBrush x:Key="AccentColorBrush" Color="{DynamicResource MahApps.Colors.Accent}" />
            <SolidColorBrush x:Key="AccentColorBrush2" Color="{DynamicResource MahApps.Colors.Accent2}" />
            <SolidColorBrush x:Key="AccentColorBrush3" Color="{DynamicResource MahApps.Colors.Accent3}" />
            <Color x:Key="AccentColor2">{StaticResource MahApps.Colors.Accent2}</Color>

            <!-- Shared outer margin for tool pages (tighter than the original 16px). -->
            <Thickness x:Key="Orbit.ToolPageMargin">10</Thickness>
            <SolidColorBrush x:Key="Orbit.UpdateBadgeBrush" Color="#FFFFC44D" />
            <FontFamily x:Key="Orbit.Fonts.Family">Segoe UI</FontFamily>
            <sys:Double x:Key="Orbit.Fonts.Size.Base">12</sys:Double>
            <FontWeight x:Key="Orbit.Fonts.Weight.Body">Normal</FontWeight>
            <Style
                x:Key="Orbit.TrapezoidTabItemStyle"
                BasedOn="{StaticResource MahAppsTrapezoidDragableTabItemStyle}"
                TargetType="{x:Type dragablz:DragablzItem}">
                <Setter Property="Background" Value="{DynamicResource AccentColorBrush2}" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush3}" />
                <Setter Property="Foreground" Value="{DynamicResource WhiteBrush}" />
                <Setter Property="Opacity" Value="0.85" />
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Opacity" Value="1.0" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style
                x:Key="Orbit.TabablzControlStyle"
                BasedOn="{StaticResource MahAppsTabablzControlStyle}"
                TargetType="{x:Type dragablz:TabablzControl}">
                <Setter Property="ShowDefaultAddButton" Value="False" />
                <Setter Property="ShowDefaultCloseButton" Value="True" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource Orbit.TrapezoidTabItemStyle}" />
            </Style>

            <Style
                BasedOn="{StaticResource Orbit.TabablzControlStyle}"
                TargetType="{x:Type dragablz:TabablzControl}">
            </Style>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{DynamicResource Orbit.Fonts.Family}" />
                <Setter Property="FontSize" Value="{DynamicResource Orbit.Fonts.Size.Base}" />
                <Setter Property="FontWeight" Value="{DynamicResource Orbit.Fonts.Weight.Body}" />
            </Style>
            <Style TargetType="{x:Type TextElement}">
                <Setter Property="FontFamily" Value="{DynamicResource Orbit.Fonts.Family}" />
                <Setter Property="FontSize" Value="{DynamicResource Orbit.Fonts.Size.Base}" />
                <Setter Property="FontWeight" Value="{DynamicResource Orbit.Fonts.Weight.Body}" />
            </Style>

            <!-- 60-30-10 color system:
                 60% base = ThemeBackground/ThemeForeground
                 30% surfaces = Gray8/Gray7/Gray6 neutrals
                 10% accent = Accent/Accent2/AccentForeground -->
            <Style
                x:Key="Orbit.Styles.Button.Default"
                BasedOn="{StaticResource MahApps.Styles.Button}"
                TargetType="Button">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Muted}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Hover}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Strong}" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="Button" BasedOn="{StaticResource Orbit.Styles.Button.Default}" />

            <Style
                x:Key="Orbit.Styles.TextBox.Default"
                BasedOn="{StaticResource MahApps.Styles.TextBox}"
                TargetType="TextBox">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Base}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
            </Style>
            <Style TargetType="TextBox" BasedOn="{StaticResource Orbit.Styles.TextBox.Default}" />

            <Style
                x:Key="Orbit.Styles.ComboBox.Default"
                BasedOn="{StaticResource MahApps.Styles.ComboBox}"
                TargetType="ComboBox">
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Base}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource Orbit.Styles.ComboBox.Default}" />

            <Style
                x:Key="Orbit.Styles.TextBox.InlineRename"
                BasedOn="{StaticResource Orbit.Styles.TextBox.Default}"
                TargetType="TextBox">
                <Setter Property="MinWidth" Value="110" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="2,0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Hover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Action.Primary}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                        <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style
                x:Key="Orbit.Styles.Button.Circle.Action"
                BasedOn="{StaticResource MahApps.Styles.Button.Circle}"
                TargetType="Button">
                <Setter Property="Width" Value="26" />
                <Setter Property="Height" Value="26" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
            </Style>

            <Style
                x:Key="Orbit.Styles.Button.Circle.Rename"
                BasedOn="{StaticResource Orbit.Styles.Button.Circle.Action}"
                TargetType="Button">
                <Setter Property="Opacity" Value="0.75" />
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=dragablz:DragablzItem}}" Value="True">
                        <Setter Property="Opacity" Value="1" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <SolidColorBrush x:Key="Orbit.Brushes.Text.Primary" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.Secondary" Color="{DynamicResource Orbit.Colors.Text.Primary}" Opacity="0.82" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.Tertiary" Color="{DynamicResource Orbit.Colors.Text.Primary}" Opacity="0.64" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnAccent" Color="{DynamicResource Orbit.Colors.Action.PrimaryForeground}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnHeader" Color="{DynamicResource Orbit.Colors.Action.PrimaryForeground}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnHeaderSecondary" Color="{DynamicResource Orbit.Colors.Action.PrimaryForeground}" Opacity="0.88" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnOverlay" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnBase" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnCard" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnSubtle" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnMuted" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnHover" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Surface.Base" Color="{DynamicResource Orbit.Colors.Surface.Base}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Surface.Card" Color="{DynamicResource Orbit.Colors.Surface.Base}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Surface.Subtle" Color="{DynamicResource MahApps.Colors.Gray9}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Surface.Muted" Color="{DynamicResource MahApps.Colors.Gray8}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Surface.Hover" Color="{DynamicResource MahApps.Colors.Gray7}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Border.Subtle" Color="{DynamicResource MahApps.Colors.Gray6}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Border.Strong" Color="{DynamicResource MahApps.Colors.Gray5}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Status.Neutral" Color="{DynamicResource MahApps.Colors.Gray5}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Status.Info" Color="{DynamicResource Orbit.Colors.Action.Secondary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Status.Success" Color="#FF4CAF50" />
            <SolidColorBrush x:Key="Orbit.Brushes.Status.Warning" Color="#FFFFC107" />
            <SolidColorBrush x:Key="Orbit.Brushes.Status.Error" Color="#FFF44336" />
            <Color x:Key="Orbit.Colors.Action.Primary">{StaticResource MahApps.Colors.Accent}</Color>
            <Color x:Key="Orbit.Colors.Action.Secondary">{StaticResource MahApps.Colors.Accent2}</Color>
            <Color x:Key="Orbit.Colors.Action.Tertiary">{StaticResource MahApps.Colors.Accent3}</Color>
            <Color x:Key="Orbit.Colors.Action.Subtle">{StaticResource MahApps.Colors.Accent4}</Color>
            <Color x:Key="Orbit.Colors.Action.PrimaryForeground">{StaticResource MahApps.Colors.AccentForeground}</Color>
            <Color x:Key="Orbit.Colors.Text.Primary">{StaticResource MahApps.Colors.ThemeForeground}</Color>
            <Color x:Key="Orbit.Colors.Surface.Base">{StaticResource MahApps.Colors.ThemeBackground}</Color>
            <SolidColorBrush x:Key="Orbit.Brushes.Action.Primary" Color="{DynamicResource Orbit.Colors.Action.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Action.Secondary" Color="{DynamicResource Orbit.Colors.Action.Secondary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Action.Tertiary" Color="{DynamicResource Orbit.Colors.Action.Tertiary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Action.Subtle" Color="{DynamicResource Orbit.Colors.Action.Subtle}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnStatus.Neutral" Color="{DynamicResource Orbit.Colors.Text.Primary}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnStatus.Info" Color="{DynamicResource Orbit.Colors.Action.PrimaryForeground}" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnStatus.Success" Color="White" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnStatus.Warning" Color="Black" />
            <SolidColorBrush x:Key="Orbit.Brushes.Text.OnStatus.Error" Color="White" />

            <!--  Orbit Grid Cell Style - for TabablzControls in Orbit View grid layout  -->
            <Style
                x:Key="OrbitGridCellStyle"
                BasedOn="{StaticResource Orbit.TabablzControlStyle}"
                TargetType="{x:Type dragablz:TabablzControl}">
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Action.Primary}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Base}" />
            </Style>

            <!--  Fallback style for MahApps toggle buttons (Orbit only consumes the square variant)  -->
            <Style x:Key="MahApps.Styles.ToggleButton.Square" TargetType="ToggleButton">
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Hover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Strong}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border
                                x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource Orbit.Brushes.Border.Strong}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="{DynamicResource Orbit.Brushes.Action.Primary}" />
                                    <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnAccent}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Border" Property="Opacity" Value="0.5" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Orbit-specific primary button style to mirror legacy accent treatment  -->
            <Style
                x:Key="MahApps.Styles.Button.Primary"
                BasedOn="{StaticResource MahApps.Styles.Button}"
                TargetType="Button">
                <Setter Property="Padding" Value="14,6" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Action.Tertiary}" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="{DynamicResource Orbit.Colors.Action.Primary}" />
                            <GradientStop Offset="1" Color="{DynamicResource Orbit.Colors.Action.Secondary}" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnAccent}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.95" />
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter Property="Opacity" Value="0.85" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.6" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!--  Shared tool header visuals  -->
            <Style x:Key="Orbit.ToolHeader" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="{DynamicResource Orbit.Colors.Action.Primary}" />
                            <GradientStop Offset="0.55" Color="{DynamicResource Orbit.Colors.Action.Secondary}" />
                            <GradientStop Offset="1" Color="{DynamicResource Orbit.Colors.Action.Tertiary}" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="14"
                            Direction="310"
                            Opacity="0.22"
                            ShadowDepth="2"
                            Color="#66000000" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Orbit.ToolHeaderIcon" TargetType="Border">
                <Setter Property="Width" Value="46" />
                <Setter Property="Height" Value="46" />
                <Setter Property="Margin" Value="0,0,10,0" />
                <Setter Property="CornerRadius" Value="23" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Background" Value="#33FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#55FFFFFF" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="12"
                            Direction="315"
                            Opacity="0.4"
                            ShadowDepth="2"
                            Color="#3F000000" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="Orbit.ToolHeaderIconGlyph" TargetType="iconPacks:PackIconMaterial">
                <Setter Property="Width" Value="22" />
                <Setter Property="Height" Value="22" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
            </Style>

            <Style x:Key="Orbit.ToolHeaderGameIcon" TargetType="iconPacks:PackIconGameIcons">
                <Setter Property="Width" Value="22" />
                <Setter Property="Height" Value="22" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
            </Style>

            <Style x:Key="Orbit.ToolHeaderIconPath" TargetType="Path">
                <Setter Property="Width" Value="22" />
                <Setter Property="Height" Value="22" />
                <Setter Property="Stretch" Value="Uniform" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Fill" Value="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
            </Style>

            <Style x:Key="Orbit.ToolHeaderTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            </Style>

            <Style x:Key="Orbit.ToolHeaderSubtitle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0,4,0,0" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
                <Setter Property="Opacity" Value="0.85" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="Orbit.ToolHeaderMetaText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="Orbit.ToolCard" TargetType="Border">
                <Setter Property="Margin" Value="0,10,0,0" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="12"
                            Opacity="0.1"
                            ShadowDepth="1.5"
                            Color="{DynamicResource Orbit.Colors.Text.Primary}" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Orbit Workbench Console primitives  -->
            <Style x:Key="Orbit.Workbench.PageRoot" TargetType="Grid">
                <Setter Property="Margin" Value="{StaticResource Orbit.ToolPageMargin}" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Base}" />
            </Style>

            <Style x:Key="Orbit.Workbench.CommandBar" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Card}" />
                <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style x:Key="Orbit.Workbench.Panel" TargetType="Border" BasedOn="{StaticResource Orbit.ToolCard}">
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="Effect" Value="{x:Null}" />
            </Style>

            <Style x:Key="Orbit.Workbench.SelectableCard" TargetType="Border" BasedOn="{StaticResource Orbit.Workbench.Panel}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Card}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Subtle}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Action.Primary}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="Orbit.Workbench.ListItem" TargetType="ListBoxItem">
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style x:Key="Orbit.Workbench.Badge" TargetType="Border">
                <Setter Property="Margin" Value="0,0,6,6" />
                <Setter Property="Padding" Value="6,2" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Muted}" />
            </Style>

            <Style x:Key="Orbit.Workbench.Badge.Primary" TargetType="Border" BasedOn="{StaticResource Orbit.Workbench.Badge}">
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Action.Primary}" />
            </Style>

            <Style x:Key="Orbit.Workbench.Badge.Secondary" TargetType="Border" BasedOn="{StaticResource Orbit.Workbench.Badge}">
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Action.Secondary}" />
            </Style>

            <Style x:Key="Orbit.Workbench.Badge.Warning" TargetType="Border" BasedOn="{StaticResource Orbit.Workbench.Badge}">
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Status.Warning}" />
            </Style>

            <Style x:Key="Orbit.Workbench.Badge.Error" TargetType="Border" BasedOn="{StaticResource Orbit.Workbench.Badge}">
                <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Status.Error}" />
            </Style>

            <Style x:Key="Orbit.Workbench.BadgeText" TargetType="TextBlock">
