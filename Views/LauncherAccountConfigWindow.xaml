<Controls:MetroWindow
    x:Class="Orbit.Views.LauncherAccountConfigWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    Title="Launcher Account Config"
    Width="980"
    Height="560"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Style="{StaticResource Orbit.Workbench.PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Orbit.ToolHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Orbit.ToolHeaderIcon}">
                    <iconPacks:PackIconMaterial Kind="AccountKey" Style="{StaticResource Orbit.ToolHeaderIconGlyph}" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Orbit.ToolHeaderTitle}" Text="Launcher Accounts" />
                    <TextBlock Style="{StaticResource Orbit.ToolHeaderSubtitle}" Text="Manage Jagex launcher account entries (stored in env_vars.json)." />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Orbit.Workbench.Panel}" Padding="0">
            <DataGrid
                x:Name="AccountsGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                IsReadOnly="False"
                SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Width="70" Binding="{Binding IsSelected}" Header="Use" />
                    <DataGridTextColumn Width="2*" Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Header="Display Name" />
                    <DataGridTextColumn Width="2*" Binding="{Binding CharacterId, UpdateSourceTrigger=PropertyChanged}" Header="Character ID" />
                    <DataGridTextColumn Width="2*" Binding="{Binding SessionId, UpdateSourceTrigger=PropertyChanged}" Header="Session ID" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Orbit.Workbench.CommandBar}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Width="90" Click="AddRow_Click" Content="Add" Style="{StaticResource Orbit.Workbench.Button}" />
                    <Button Width="90" Click="RemoveRow_Click" Content="Remove" Style="{StaticResource Orbit.Workbench.Button}" />
                </StackPanel>
                <Border
                    Margin="12,0"
                    Padding="12,8"
                    Background="{DynamicResource Orbit.Brushes.Surface.Muted}"
                    BorderBrush="{DynamicResource Orbit.Brushes.Border.Subtle}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox
                            x:Name="FullWaitCheckBox"
                            VerticalAlignment="Center"
                            Content="Full wait for dock"
                            Margin="0,0,12,0" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            Style="{StaticResource Orbit.Workbench.MetaText}"
                            Text="Delay" />
                        <Slider
                            x:Name="LaunchDelaySlider"
                            Width="150"
                            Minimum="5"
                            Maximum="30"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            VerticalAlignment="Center">
                            <Slider.Style>
                                <Style TargetType="Slider">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=FullWaitCheckBox}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Slider.Style>
                        </Slider>
                        <Border
                            Margin="8,0,0,0"
                            Padding="8,2"
                            Background="{DynamicResource Orbit.Brushes.Action.Primary}"
                            CornerRadius="10">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Orbit.Brushes.Text.OnAccent}"
                                Text="{Binding ElementName=LaunchDelaySlider, Path=Value, StringFormat={}{0:0}s}" />
                        </Border>
                    </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Width="130" Click="LaunchSelected_Click" Content="Launch Selected" Style="{StaticResource Orbit.Workbench.Button.Primary}" />
                    <Button Width="90" Click="Cancel_Click" Content="Cancel" Style="{StaticResource Orbit.Workbench.Button}" />
                    <Button Width="90" Click="Save_Click" Content="Save" Style="{StaticResource Orbit.Workbench.Button}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Controls:MetroWindow>
