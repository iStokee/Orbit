<ui:FluentWindow x:Class="Orbit.Views.SettingsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:converters="clr-namespace:Orbit.Converters"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                      mc:Ignorable="d"
                      Title="Orbit Settings"
                      Icon="{DynamicResource Orbit.IconImage}"
                      Width="520"
                      Height="520"
                      MinWidth="420"
                      MinHeight="420"
                      WindowStartupLocation="CenterOwner"
                      Background="{DynamicResource Orbit.Brushes.Canvas.Background}"
                      Foreground="{DynamicResource Orbit.Brushes.Text.Primary}">

    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <StackPanel Margin="20" Orientation="Vertical">
            <TextBlock Text="Floating Menu" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}"/>

            <StackPanel Orientation="Vertical" Margin="0,4,0,0">
                <TextBlock FontWeight="SemiBold" Text="Hide after" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <Slider Minimum="0.5" Maximum="8" TickFrequency="0.5" IsSnapToTickEnabled="True"
                        Value="{Binding FloatingMenuInactivitySeconds, Mode=TwoWay}"
                        Margin="0,0,0,2" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           Text="{Binding FloatingMenuInactivitySeconds, StringFormat={}{0:0.0}s}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                <TextBlock FontWeight="SemiBold" Text="Handle (button) opacity" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <Slider Minimum="0.35" Maximum="1" TickFrequency="0.05" Margin="0,0,0,2"
                        Value="{Binding FloatingMenuOpacity, Mode=TwoWay}" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           Text="{Binding FloatingMenuOpacity, StringFormat={}{0:P0}}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                <TextBlock FontWeight="SemiBold" Text="Menu background opacity" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <Slider Minimum="0.2" Maximum="1" TickFrequency="0.05" Margin="0,0,0,2"
                        Value="{Binding FloatingMenuBackgroundOpacity, Mode=TwoWay}" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           Text="{Binding FloatingMenuBackgroundOpacity, StringFormat={}{0:P0}}" />
            </StackPanel>

            <CheckBox
                Content="Auto direction (expand inward from nearest edge)"
                IsChecked="{Binding FloatingMenuAutoDirection, Mode=TwoWay}"
                Margin="0,12,0,0" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}"
                           Text="Manual direction" />
                <ComboBox Width="160"
                          Margin="12,0,0,0"
                          IsEnabled="{Binding FloatingMenuAutoDirection, Converter={StaticResource InverseBooleanConverter}}"
                          ItemsSource="{Binding FloatingMenuDirectionOptions}"
                          SelectedItem="{Binding FloatingMenuDirection, Mode=TwoWay}" />
            </StackPanel>

            <Separator Margin="0,16,0,12" Background="{DynamicResource Orbit.Brushes.Card.Border}" />

            <TextBlock Text="Dock Zones" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"
                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}"/>

            <StackPanel Orientation="Vertical" Margin="0,4,0,0">
                <TextBlock FontWeight="SemiBold" Text="Edge snap distance" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <TextBlock FontSize="11" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           TextWrapping="Wrap"
                           Text="Distance from screen edges to trigger snap zones (pixels)" />
                <Slider Minimum="40" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True"
                        Value="{Binding FloatingMenuDockEdgeThreshold, Mode=TwoWay}"
                        Margin="0,0,0,2" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           Text="{Binding FloatingMenuDockEdgeThreshold, StringFormat={}{0:0}px}" />
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,12,0,0">
                <TextBlock FontWeight="SemiBold" Text="Corner snap distance" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                <TextBlock FontSize="11" Margin="0,0,0,4"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           TextWrapping="Wrap"
                           Text="Distance from corners to trigger corner snap zones (pixels)" />
                <Slider Minimum="60" Maximum="250" TickFrequency="10" IsSnapToTickEnabled="True"
                        Value="{Binding FloatingMenuDockCornerThreshold, Mode=TwoWay}"
                        Margin="0,0,0,2" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                           Text="{Binding FloatingMenuDockCornerThreshold, StringFormat={}{0:0}px}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ui:FluentWindow>
