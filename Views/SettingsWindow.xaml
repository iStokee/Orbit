<Controls:MetroWindow x:Class="Orbit.Views.SettingsWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      xmlns:converters="clr-namespace:Orbit.Converters"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      mc:Ignorable="d"
                      Title="Orbit Settings"
                      Icon="{DynamicResource Orbit.IconImage}"
                      Width="520"
                      Height="520"
                      MinWidth="420"
                      MinHeight="420"
                      WindowStartupLocation="CenterOwner"
                      Foreground="{DynamicResource Orbit.Brushes.Text.Primary}"
                      TitleCharacterCasing="Normal">

    <Controls:MetroWindow.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Controls:MetroWindow.Resources>

    <Controls:MetroWindow.IconTemplate>
        <DataTemplate>
            <iconPacks:PackIconMaterial Kind="Tune" Height="20" Width="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </DataTemplate>
    </Controls:MetroWindow.IconTemplate>

    <Grid Style="{StaticResource Orbit.Workbench.DialogRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Orbit.ToolHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Orbit.ToolHeaderIcon}">
                    <iconPacks:PackIconMaterial Kind="Tune" Style="{StaticResource Orbit.ToolHeaderIconGlyph}" />
                </Border>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource Orbit.ToolHeaderTitle}" Text="Quick Settings" />
                    <TextBlock Style="{StaticResource Orbit.ToolHeaderSubtitle}" Text="Tune floating menu visibility, snap behavior, and launch ergonomics." />
                </StackPanel>
            </Grid>
        </Border>

	    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
	        <StackPanel Orientation="Vertical">
	            <Border Style="{StaticResource Orbit.Workbench.DialogPanel}">
	                <StackPanel>
	            <TextBlock Text="Floating Menu" Style="{StaticResource Orbit.Workbench.SectionTitle}" Margin="0,0,0,10"/>

	            <StackPanel Orientation="Vertical" Margin="0,4,0,0">
	                <TextBlock Text="Hide after" Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.FieldLabel}" />
                <Slider Minimum="0.5" Maximum="8" TickFrequency="0.5" IsSnapToTickEnabled="True"
                        Value="{Binding FloatingMenuInactivitySeconds, Mode=TwoWay}"
                        Margin="0,0,0,2" />
	                <TextBlock Style="{StaticResource Orbit.Workbench.MetaText}"
	                           Text="{Binding FloatingMenuInactivitySeconds, StringFormat={}{0:0.0}s}" />
	            </StackPanel>

	            <StackPanel Orientation="Vertical" Margin="0,8,0,0">
	                <TextBlock Text="Handle (button) opacity" Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.FieldLabel}" />
                <Slider Minimum="0.35" Maximum="1" TickFrequency="0.05" Margin="0,0,0,2"
                        Value="{Binding FloatingMenuOpacity, Mode=TwoWay}" />
	                <TextBlock Style="{StaticResource Orbit.Workbench.MetaText}"
	                           Text="{Binding FloatingMenuOpacity, StringFormat={}{0:P0}}" />
	            </StackPanel>

	            <StackPanel Orientation="Vertical" Margin="0,8,0,0">
	                <TextBlock Text="Menu background opacity" Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.FieldLabel}" />
                <Slider Minimum="0.2" Maximum="1" TickFrequency="0.05" Margin="0,0,0,2"
                        Value="{Binding FloatingMenuBackgroundOpacity, Mode=TwoWay}" />
	                <TextBlock Style="{StaticResource Orbit.Workbench.MetaText}"
	                           Text="{Binding FloatingMenuBackgroundOpacity, StringFormat={}{0:P0}}" />
            </StackPanel>

            <Controls:ToggleSwitch Header="Auto direction (expand inward from nearest edge)"
                                   IsOn="{Binding FloatingMenuAutoDirection, Mode=TwoWay}"
                                   Margin="0,10,0,0" />

	            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,0">
	                <TextBlock VerticalAlignment="Center"
	                           Style="{StaticResource Orbit.Workbench.FieldLabel}"
	                           Text="Manual direction" />
                <ComboBox Width="160"
                          Margin="10,0,0,0"
                          IsEnabled="{Binding FloatingMenuAutoDirection, Converter={StaticResource InverseBooleanConverter}}"
                          ItemsSource="{Binding FloatingMenuDirectionOptions}"
                          SelectedItem="{Binding FloatingMenuDirection, Mode=TwoWay}" />
            </StackPanel>

	            <Border Style="{StaticResource Orbit.Workbench.Separator}" />

	            <TextBlock Text="Dock Zones" Style="{StaticResource Orbit.Workbench.SectionTitle}" Margin="0,0,0,10"/>

            <StackPanel Orientation="Vertical" Margin="0,4,0,0">
	                <TextBlock Text="Edge snap distance" Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.FieldLabel}" />
	                <TextBlock Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.HelperText}"
	                           TextWrapping="Wrap"
	                           Text="Distance from screen edges to trigger snap zones (pixels)" />
                <Slider Minimum="40" Maximum="200" TickFrequency="10" IsSnapToTickEnabled="True"
                        Value="{Binding FloatingMenuDockEdgeThreshold, Mode=TwoWay}"
                        Margin="0,0,0,2" />
	                <TextBlock Style="{StaticResource Orbit.Workbench.MetaText}"
	                           Text="{Binding FloatingMenuDockEdgeThreshold, StringFormat={}{0:0}px}" />
	            </StackPanel>

	            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
	                <TextBlock Text="Corner snap distance" Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.FieldLabel}" />
	                <TextBlock Margin="0,0,0,4"
	                           Style="{StaticResource Orbit.Workbench.HelperText}"
	                           TextWrapping="Wrap"
	                           Text="Distance from corners to trigger corner snap zones (pixels)" />
                <Slider Minimum="60" Maximum="250" TickFrequency="10" IsSnapToTickEnabled="True"
                        Value="{Binding FloatingMenuDockCornerThreshold, Mode=TwoWay}"
                        Margin="0,0,0,2" />
	                <TextBlock Style="{StaticResource Orbit.Workbench.MetaText}"
	                           Text="{Binding FloatingMenuDockCornerThreshold, StringFormat={}{0:0}px}" />
	            </StackPanel>
	                </StackPanel>
	            </Border>
	        </StackPanel>
	    </ScrollViewer>
    </Grid>
</Controls:MetroWindow>
