<UserControl
    x:Class="Orbit.Views.UnifiedToolsManagerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Orbit.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="900"
    Background="{DynamicResource Orbit.Brushes.Surface.Base}"
    Foreground="{DynamicResource Orbit.Brushes.Text.Primary}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BooleanToAccentBrushConverter x:Key="BooleanToAccentBrushConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Style="{StaticResource Orbit.Workbench.PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border Grid.Row="0" Style="{StaticResource Orbit.ToolHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Orbit.ToolHeaderIcon}">
                    <iconPacks:PackIconMaterial Kind="ViewDashboard" Style="{StaticResource Orbit.ToolHeaderIconGlyph}" />
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock
                        Style="{StaticResource Orbit.ToolHeaderTitle}"
                        Text="Tools &amp; Plugins Dashboard" />
                    <TextBlock
                        Style="{StaticResource Orbit.ToolHeaderSubtitle}"
                        Text="Discover built-in utilities, manage plugin lifecycle, and curate quick access for scripters." />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Toolbar  -->
        <Border
            Grid.Row="1"
            Style="{StaticResource Orbit.Workbench.CommandBar}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Action Buttons  -->
                <WrapPanel Grid.Row="0" Orientation="Horizontal">
                    <Button
                        Command="{Binding ImportPluginCommand}"
                        Style="{DynamicResource Orbit.Workbench.Button.Primary}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,8,0" Kind="Import" />
                            <TextBlock Text="Import Plugin" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{Binding AutoLoadAllCommand}"
                        Style="{DynamicResource Orbit.Workbench.Button}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,8,0" Kind="PlaylistPlay" />
                            <TextBlock Text="Auto-Load Plugins" />
                        </StackPanel>
                    </Button>

                    <Button
                        Command="{Binding RefreshCommand}"
                        Style="{DynamicResource Orbit.Workbench.Button}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Width="16" Height="16" Margin="0,0,8,0" Kind="Refresh" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <!--  Search Box  -->
                <TextBox
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Controls:TextBoxHelper.ClearTextButton="True"
                    Controls:TextBoxHelper.Watermark="Search tools and plugins..."
                    Text="{Binding SearchFilter, UpdateSourceTrigger=PropertyChanged}">
                    <Controls:TextBoxHelper.ButtonContent>
                        <iconPacks:PackIconMaterial
                            Width="16"
                            Height="16"
                            Kind="Magnify" />
                    </Controls:TextBoxHelper.ButtonContent>
                </TextBox>
            </Grid>
        </Border>

        <!--  Tools Grid  -->
        <ScrollViewer
            Grid.Row="2"
            Padding="20,16"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ToolCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border
                            Margin="0,0,16,16"
                            Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Orbit.Workbench.SelectableCard}">
                                    <Setter Property="Margin" Value="0,0,16,16" />
                                    <Setter Property="Width" Value="380" />
                                    <Setter Property="Padding" Value="16" />
                                    <Setter Property="Background" Value="{DynamicResource Orbit.Brushes.Surface.Base}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Border.Subtle}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlugin}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Orbit.Brushes.Action.Secondary}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!--  Header  -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Icon  -->
                                    <Border
                                        Grid.Column="0"
                                        Margin="0,0,12,0"
                                        Padding="8"
                                        Background="{DynamicResource Orbit.Brushes.Action.Primary}"
                                        CornerRadius="4">
                                        <iconPacks:PackIconMaterial
                                            Width="24"
                                            Height="24"
                                            Foreground="{DynamicResource Orbit.Brushes.Text.OnAccent}"
                                            Kind="{Binding Icon}" />
                                    </Border>

                                    <!--  Name and Type  -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
	                                        <TextBlock
	                                            Style="{StaticResource Orbit.Workbench.SectionTitle}"
	                                            Text="{Binding DisplayName}" />
                                        <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                            <Border
                                                Padding="6,2"
                                                Background="{DynamicResource Orbit.Brushes.Action.Primary}"
                                                CornerRadius="2">
                                                <TextBlock
                                                    FontSize="10"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource Orbit.Brushes.Text.OnAccent}"
                                                    Text="{Binding ToolType}" />
                                            </Border>
                                            <TextBlock
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                FontSize="11"
                                                Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                                                Text="{Binding Version, StringFormat='v{0}'}"
                                                Visibility="{Binding IsPlugin, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!--  Menu Visibility Toggle  -->
                                    <Controls:ToggleSwitch
                                        Grid.Column="2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        IsOn="{Binding IsVisibleInMenu}"
                                        OffContent="Hidden"
                                        OnContent="In Menu" />
                                </Grid>

                                <!--  Description  -->
                                <TextBlock
                                    Grid.Row="1"
                                    Margin="0,10,0,0"
                                    FontSize="13"
                                    Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}"
                                    Text="{Binding Description}"
                                    TextWrapping="Wrap" />

                                <!--  Plugin Details  -->
                                <StackPanel
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    Visibility="{Binding IsPlugin, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}">
                                        <Run Text="Author:" />
                                        <Run Foreground="{DynamicResource Orbit.Brushes.Action.Primary}" Text="{Binding Author, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource Orbit.Brushes.Text.Secondary}">
                                        <Run Text="Loaded:" />
                                        <Run Text="{Binding LoadedAt, Mode=OneWay}" />
                                    </TextBlock>
                                    <Expander
                                        Margin="0,4,0,0"
                                        Header="Path"
                                        IsExpanded="False">
                                        <TextBlock
                                            Margin="0,4,0,0"
                                            FontFamily="Consolas"
                                            FontSize="10"
                                            Foreground="{DynamicResource Orbit.Brushes.Text.Tertiary}"
                                            Text="{Binding PluginPath}"
                                            TextWrapping="Wrap" />
                                    </Expander>
                                </StackPanel>

                                <!--  Actions  -->
                                <StackPanel
                                    Grid.Row="3"
                                    Margin="0,10,0,0"
                                    Orientation="Horizontal"
                                    Visibility="{Binding IsPlugin, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button
                                        Margin="0,0,8,0"
                                        Command="{Binding ReloadCommand}"
                                        Style="{DynamicResource Orbit.Workbench.Button.Primary}">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Width="14" Height="14" Margin="0,0,4,0" Kind="Reload" />
                                            <TextBlock Text="Hot Reload" />
                                        </StackPanel>
                                    </Button>

                                    <Button
                                        Command="{Binding UnloadCommand}"
                                        Style="{DynamicResource Orbit.Workbench.Button}">
                                        <StackPanel Orientation="Horizontal">
                                            <iconPacks:PackIconMaterial Width="14" Height="14" Margin="0,0,4,0" Kind="Close" />
                                            <TextBlock Text="Unload" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!--  Status Bar  -->
        <Border
            Grid.Row="3"
            Padding="16,8"
            Style="{StaticResource Orbit.Workbench.Panel}">
            <Grid>
	                <TextBlock
	                    VerticalAlignment="Center"
	                    Style="{StaticResource Orbit.Workbench.MetaText}"
	                    Text="{Binding StatusMessage}" />

                <Controls:ProgressRing
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Right"
                    IsActive="{Binding IsLoading}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
