<UserControl x:Class="Orbit.Views.McpControlCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1460">

    <Grid Margin="{StaticResource Orbit.ToolPageMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource Orbit.ToolHeader}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Orbit.ToolHeaderIcon}">
                    <iconPacks:PackIconMaterial Kind="LanConnect" Style="{StaticResource Orbit.ToolHeaderIconGlyph}" />
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="MCP Control Center" Style="{StaticResource Orbit.ToolHeaderTitle}" />
                    <TextBlock Text="Manage MCP runtime behavior, probe per-session bridges, and inspect responses without relying on console output."
                               Style="{StaticResource Orbit.ToolHeaderSubtitle}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Margin="10,0,0,0"
                        Padding="10,6"
                        CornerRadius="8"
                        VerticalAlignment="Center"
                        Background="{DynamicResource MahApps.Brushes.Accent4}">
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding StatusSummary}"
                                   Foreground="{DynamicResource Orbit.Brushes.Text.OnAccent}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="430" />
                        <Controls:ProgressRing DockPanel.Dock="Right"
                                               Width="16"
                                               Height="16"
                                               IsActive="{Binding IsBusy}" />
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                <StackPanel>
                    <Border Style="{StaticResource Orbit.ToolCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Policy" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />

                            <Controls:ToggleSwitch Grid.Row="1" Margin="0,10,0,0"
                                                   Header="Auto-start MCP runtime on inject"
                                                   IsOn="{Binding AutoStartRuntimeOnInject, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" Margin="0,8,0,0" TextWrapping="Wrap" Opacity="0.75"
                                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}"
                                       Text="When enabled, Orbit sends START_RUNTIME after successful injection. Disable for manual runtime lifecycle control." />

                            <StackPanel Grid.Row="3" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Auto probe every"
                                               Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                    <xctk:IntegerUpDown Grid.Column="1" Margin="8,0,8,0" Width="72" Minimum="1" Maximum="30"
                                                        Value="{Binding AutoProbeSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="seconds"
                                               Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                    <Controls:ToggleSwitch Grid.Column="4" Margin="10,0,0,0" Header="Enabled"
                                                           IsOn="{Binding AutoProbeEnabled, Mode=TwoWay}" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Orbit.ToolCard}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock Text="Sidecar Artifacts" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                <Button DockPanel.Dock="Right" Command="{Binding ValidateSidecarCommand}" Padding="10,4"
                                        Content="Revalidate" />
                            </DockPanel>

                            <TextBlock Grid.Row="1" Margin="0,10,0,0" Text="{Binding SidecarPath}" FontFamily="Consolas"
                                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" TextWrapping="Wrap" />

                            <Border Grid.Row="2" Margin="0,10,0,0" Padding="10" CornerRadius="6"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource MahApps.Brushes.Gray6}"
                                    Background="{DynamicResource MahApps.Brushes.Gray9}">
                                <TextBlock Text="{Binding SidecarArtifactsSummary}" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                            </Border>

                            <Separator Grid.Row="3" Margin="0,12,0,8" />

                            <DockPanel Grid.Row="4" LastChildFill="False">
                                <TextBlock Text="Native Injector MCP Settings" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                <Button DockPanel.Dock="Right" Margin="8,0,0,0" Command="{Binding SaveInjectorSettingsCommand}" Padding="10,4"
                                        Content="Save" />
                                <Button DockPanel.Dock="Right" Command="{Binding ReloadInjectorSettingsCommand}" Padding="10,4"
                                        Content="Reload" />
                            </DockPanel>

                            <Grid Grid.Row="5" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding InjectorSettingsPath}" FontFamily="Consolas"
                                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" Opacity="0.8" TextWrapping="Wrap" />
                                <Controls:ToggleSwitch Grid.Row="1" Margin="0,8,0,0" Header="MCP_AUTOSTART"
                                                       IsOn="{Binding BasicInjectorAutoStart, Mode=TwoWay}" />
                                <Controls:ToggleSwitch Grid.Row="2"
                                                       Margin="0,8,0,0"
                                                       Header="Override MCP server path (Advanced)"
                                                       IsOn="{Binding BasicInjectorServerPathOverrideEnabled, Mode=TwoWay}" />

                                <StackPanel Grid.Row="3"
                                            Margin="0,8,0,0"
                                            Visibility="{Binding BasicInjectorServerPathOverrideEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Optional explicit path for MCP server launch. Leave override OFF for default Orbit sidecar discovery."
                                               TextWrapping="Wrap"
                                               Opacity="0.78"
                                               Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                    <TextBlock Margin="0,6,0,2"
                                               Text="MCP_SERVER_PATH"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                    <TextBox Text="{Binding BasicInjectorServerPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Example: C:\Orbit\MESharp.McpServer.exe" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Orbit.ToolCard}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock Text="Session Probes" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                                <Button DockPanel.Dock="Right" Command="{Binding RefreshSessionsCommand}" Padding="10,4"
                                        Content="Refresh Sessions" />
                            </DockPanel>

                            <ComboBox Grid.Row="1" Margin="0,10,0,0" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel>
                                            <iconPacks:PackIconMaterial Kind="{Binding Icon}" Width="16" Height="16" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       Text="{Binding SelectedSessionSummary}"
                                       TextWrapping="Wrap"
                                       Opacity="0.82"
                                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />

                            <WrapPanel Grid.Row="3" Margin="0,10,0,0">
                                <Button Command="{Binding StartRuntimeCommand}" Content="Start Runtime" Margin="0,0,8,8" MinWidth="154" />
                                <Button Command="{Binding ProbeStatusCommand}" Content="Probe Status" Margin="0,0,8,8" MinWidth="154" />
                                <Button Command="{Binding ProbeCapabilitiesCommand}" Content="Capabilities" Margin="0,0,8,8" MinWidth="154" />
                                <Button Command="{Binding ProbeQuickSnapshotCommand}" Content="Quick Snapshot" Margin="0,0,8,8" MinWidth="154" />
                                <Button Command="{Binding ProbeDungeoneeringSnapshotCommand}" Content="DG Snapshot" Margin="0,0,8,8" MinWidth="154" />
                                <Button Command="{Binding ProbeDoActionSignalsCommand}" Content="DoAction Signals" Margin="0,0,8,8" MinWidth="154" />
                            </WrapPanel>

                            <TextBlock Grid.Row="4" Margin="0,6,0,0" Text="{Binding StatusSummary}" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" Opacity="0.85" />
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource MahApps.Brushes.Gray6}" />

            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="240" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="1.1*" MinHeight="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Orbit.ToolCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="Response Payload" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                            <Button DockPanel.Dock="Right" Command="{Binding CopyResponseCommand}" Padding="10,4"
                                    Content="Copy JSON" />
                        </DockPanel>

                        <TextBox Grid.Row="1" Margin="0,10,0,0" Text="{Binding LastResponseJson}" IsReadOnly="True"
                                 AcceptsReturn="True" AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12"
                                 TextWrapping="NoWrap" />
                    </Grid>
                </Border>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource MahApps.Brushes.Gray6}" />

                <Border Grid.Row="2" Style="{StaticResource Orbit.ToolCard}" Margin="0,10,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="False">
                            <TextBlock Text="Activity Log" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Orbit.Brushes.Text.Primary}" />
                            <Button DockPanel.Dock="Right" Command="{Binding ClearLogCommand}" Padding="10,4"
                                    Content="Clear" />
                        </DockPanel>

                        <ListBox Grid.Row="1"
                                 Margin="0,10,0,0"
                                 ItemsSource="{Binding ActivityLog}"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
