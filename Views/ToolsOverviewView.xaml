<UserControl x:Class="Orbit.Views.ToolsOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1000">

    <Grid Style="{StaticResource Orbit.Workbench.PageRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Orbit.ToolHeader}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Orbit.ToolHeaderIcon}">
                            <iconPacks:PackIconMaterial Kind="ViewDashboard" Style="{StaticResource Orbit.ToolHeaderIconGlyph}" />
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Tools Management"
                                      Style="{StaticResource Orbit.ToolHeaderTitle}" />
                            <TextBlock Text="Manage Orbit tools and their visibility in the floating menu"
                                      Style="{StaticResource Orbit.ToolHeaderSubtitle}" />
                        </StackPanel>

                        <Border Grid.Column="2" Style="{StaticResource Orbit.ToolHeaderStatus}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center" Kind="ViewDashboard" Foreground="{DynamicResource Orbit.Brushes.Text.OnHeader}" />
                                <TextBlock Style="{StaticResource Orbit.ToolHeaderMetaText}" Text="Dragablz workbench" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

        <Border Grid.Row="1" Style="{StaticResource Orbit.Workbench.CommandBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Style="{StaticResource Orbit.Workbench.Badge.Primary}">
                        <TextBlock Style="{StaticResource Orbit.Workbench.BadgeText.OnAccent}" Text="Floating Menu" />
                    </Border>
                    <TextBlock
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource Orbit.Workbench.HelperText}"
                        Text="Control quick-access visibility without removing tools from the workbench." />
                </StackPanel>
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Style="{StaticResource Orbit.Workbench.MetaText}"
                    Text="{Binding Tools.Count, StringFormat={}{0} registered tools}" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource Orbit.Workbench.Panel}">
                    <StackPanel>

                        <!-- Tools List -->
                        <ItemsControl ItemsSource="{Binding Tools}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="14"
                                        Style="{StaticResource Orbit.Workbench.SelectableCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Icon -->
                                            <Border Grid.Column="0"
                                                   Width="48"
                                                   Height="48"
                                                   Background="{DynamicResource Orbit.Brushes.Action.Primary}"
                                                   CornerRadius="8"
                                                   VerticalAlignment="Top">
                                                <iconPacks:PackIconMaterial Kind="{Binding Icon, Mode=OneWay}"
                                                                           Width="28"
                                                                           Height="28"
                                                                           Margin="0,2,0,0"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource Orbit.Brushes.Text.OnAccent}" />
                                            </Border>

                                            <!-- Tool Info -->
                                            <StackPanel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                                                <TextBlock
                                                    Style="{StaticResource Orbit.Workbench.SectionTitle}"
                                                    Text="{Binding DisplayName, Mode=OneWay}" />
                                                <TextBlock
                                                    Margin="0,4,0,0"
                                                    Style="{StaticResource Orbit.Workbench.HelperText}"
                                                    Text="{Binding Description, Mode=OneWay}"
                                                    TextWrapping="Wrap" />
                                                <TextBlock
                                                    Margin="0,6,0,0"
                                                    Style="{StaticResource Orbit.Workbench.MetaText}">
                                                    <Run Text="Key:" />
                                                    <Run Text="{Binding Key, Mode=OneWay}" FontFamily="Consolas" />
                                                </TextBlock>
                                            </StackPanel>

                                            <!-- Visibility Toggle -->
                                            <Controls:ToggleSwitch Grid.Column="2"
                                                                  Header="Show in menu"
                                                                  IsOn="{Binding IsVisibleInMenu, Mode=TwoWay}"
                                                                  VerticalAlignment="Center"
                                                                  OnContent=""
                                                                  OffContent="" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Style="{StaticResource Orbit.Workbench.Panel}" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <iconPacks:PackIconMaterial
                    Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource Orbit.Brushes.Action.Primary}"
                    Kind="InformationOutline" />
                <TextBlock
                    VerticalAlignment="Center"
                    Style="{StaticResource Orbit.Workbench.MetaText}"
                    Text="Plugins and built-in tools remain available through tabs even when hidden from the floating menu." />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
